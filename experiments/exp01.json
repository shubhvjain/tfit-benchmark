{
  "type": "run_tool",
  "about": "To run CoRegTor on multiple bulk tissue gene expression datasets from GTEx portal",
  "tags": [],
  "rerun": false,
  "datasets": [
    "amygdala",
    "bladder",
    "blood",
    "cortex-ba9",
    "heart_left_ventricle",
    "heart_atrial_appendage",
    "hypothalamus",
    "kidney_cortex",
    "lung",
    "muscle_skeletal",
    "thyroid",
    "luad",
    "lusc"
  ],
  "target": {
    "type": "no_tf",
    "non_zero_threshold": 0.8
  },
  "tf": {
    "non_zero_threshold": 0.8
  },
  "tools": ["coregtor"],
  "tool_run": {
    "coregtor": {
      "create_model": {
        "model": "rf",
        "model_options": {
          "max_depth": 5,
          "n_jobs": -1,
          "n_estimators": 1000,
          "random_state": 120
        }
      },
      "tree_paths": {},
      "create_context": {
        "method": "tree_paths"
      },
      "transform_context": [
        {
          "id": "default",
          "method": "gene_frequency",
          "normalize": false,
          "min_frequency": 1
        }
      ],
      "compare_context": [
        {
          "id": "default",
          "method": "cosine",
          "transformation_id": "default",
          "convert_to_distance": false
        }
      ]
    }
  },
  "tool_result": {
    "coregtor": {
      "save_similarity_matrix":true,
      "save_all_clusters":true,
      "clustering": [
        {
          "id": "default",
          "matrix_id": "default",
          "method": "hierarchical_clustering",
          "method_options": {
            "auto_threshold": "inconsistency",
            "cluster_selection":"silhouette"
          }
        }
      ]
    }
  },
  "results": [
    {
      "name": "coregtor_plots",
      "type": "tool_comparison_plots",
      "datasets": [
        {
          "name": "kidney_cortex",
          "tools": {
           
            "coregtor": "result_default"
          }
        },
        {
          "name": "heart_atrial_appendage",
          "tools": {
           
            "coregtor": "result_default"
          }
        },

        {
          "name": "amygdala",
          "tools": {
           
            "coregtor": "result_default"
          }
        },
        {
          "name": "bladder",
          "tools": {
          
            "coregtor": "result_default"
          }
        },
        {
          "name": "blood",
          "tools": {
           
            "coregtor": "result_default"
          }
        },
       
        {
          "name": "lung",
          "tools": {
           
            "coregtor": "result_default"
          }
        },

        {
          "name": "cortex-ba9",
          "tools": {
          
            "coregtor": "result_default"
          }
        },
        {
          "name": "hypothalamus",
          "tools": {
          
            "coregtor": "result_default"
          }
        },
        {
          "name": "muscle_skeletal",
          "tools": {
           
            "coregtor": "result_default"
          }
        }
      ]
    }
  ]
}
