Bootstrap: docker
From: bioconductor/bioconductor_docker:RELEASE_3_19

%post
    R -e "install.packages(c('jsonlite', 'arrow'), repos='https://cloud.r-project.org')"
    R -e "BiocManager::install(c('TCGAbiolinks', 'SummarizedExperiment'), ask=FALSE, update=FALSE)"

%environment
    export LC_ALL=C

%runscript
    cd /app
    exec "$@"